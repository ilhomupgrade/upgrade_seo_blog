# Keystatic GitHub mode (для продакшена)
# Создай GitHub App: https://keystatic.com/docs/github-mode
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
# PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=

# Perplexity API (генерация и анализ статей)
# Получить: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=
