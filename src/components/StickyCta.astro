<div id="sticky-cta" class="sticky-cta" hidden>
  <div class="sticky-cta__inner">
    <span class="sticky-cta__text">
      <strong>Бесплатный мини-курс по ИИ</strong>
      <span class="sticky-cta__sub">7 уроков для бизнеса</span>
    </span>
    <a href="https://upgrade-agency.ru/ai-course" target="_blank" rel="noopener" class="sticky-cta__btn">
      Получить
    </a>
    <button id="sticky-cta-close" class="sticky-cta__close" aria-label="Закрыть">&times;</button>
  </div>
</div>

<script is:inline>
  (function () {
    var el = document.getElementById('sticky-cta');
    var closeBtn = document.getElementById('sticky-cta-close');
    if (!el || !closeBtn) return;
    if (localStorage.getItem('cta-closed') === '1') return;

    setTimeout(function () {
      el.hidden = false;
      requestAnimationFrame(function () { el.classList.add('is-visible'); });
    }, 2000);

    closeBtn.addEventListener('click', function () {
      el.classList.remove('is-visible');
      setTimeout(function () { el.hidden = true; }, 250);
      localStorage.setItem('cta-closed', '1');
    });
  })();
</script>

<style>
  .sticky-cta {
    position: fixed;
    bottom: 1rem;
    left: 50%;
    transform: translate(-50%, 100px);
    max-width: calc(100% - 2rem);
    z-index: 50;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
  }
  .sticky-cta.is-visible {
    opacity: 1;
    transform: translate(-50%, 0);
    pointer-events: auto;
  }
  .sticky-cta__inner {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0.75rem 0.75rem 1.25rem;
    background: #111;
    border: 1px solid var(--border);
    border-radius: 9999px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(8px);
  }
  .sticky-cta__text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .sticky-cta__text strong {
    color: var(--text);
    font-size: 0.9375rem;
    font-weight: 600;
  }
  .sticky-cta__sub {
    color: var(--text-muted);
    font-size: 0.8125rem;
  }
  .sticky-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 1.125rem;
    background: #2563eb;
    color: #fff !important;
    border-radius: 9999px;
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none !important;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .sticky-cta__btn:hover { background: #1d4ed8; }
  .sticky-cta__close {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 9999px;
    transition: color 0.2s;
  }
  .sticky-cta__close:hover { color: var(--text); }

  @media (max-width: 520px) {
    .sticky-cta__sub { display: none; }
    .sticky-cta__inner { padding: 0.625rem 0.625rem 0.625rem 1rem; gap: 0.75rem; }
  }
</style>
