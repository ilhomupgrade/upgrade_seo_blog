---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  type?: string;
}

const {
  title,
  description,
  image = '/og-default.jpg',
  canonical,
  noindex = false,
  type = 'website',
} = Astro.props;

const siteTitle = `${title} | Upgrade`;
const url = new URL(Astro.url.pathname, Astro.site);
const canonicalUrl = canonical ?? url.toString();
const imageUrl = new URL(image, Astro.site).toString();
---

<title>{siteTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:locale" content="ru_RU" />
<meta property="og:site_name" content="Upgrade" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />

<!-- Robots -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Yandex -->
<meta name="yandex-verification" content="PLACEHOLDER" />

<!-- Theme -->
<meta name="theme-color" content="#0a0a0a" />

<!-- Feeds -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="Upgrade - Блог" href="/rss.xml" />
