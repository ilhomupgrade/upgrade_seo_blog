---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const date = post.data.pubDate.toLocaleDateString('ru-RU', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const cover = post.data.cover || '/og-default.jpg';
const primaryTag = post.data.tags?.[0];
---

<a href={`/blog/${post.id}/`} class="post-card">
  <div class="cover">
    <img src={cover} alt={post.data.title} loading="lazy" decoding="async" />
  </div>
  <div class="body">
    {primaryTag && <span class="pill">{primaryTag}</span>}
    <h3>{post.data.title}</h3>
    <p>{post.data.description}</p>
    <div class="meta">
      <span class="author">{post.data.author || 'Upgrade'}</span>
      <span class="dot">&bull;</span>
      <time datetime={post.data.pubDate.toISOString()}>{date}</time>
    </div>
  </div>
</a>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
  }
  .cover {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-radius: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    margin-bottom: 1.25rem;
  }
  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .post-card:hover .cover img {
    transform: scale(1.03);
  }
  .body {
    display: flex;
    flex-direction: column;
  }
  .pill {
    display: inline-block;
    align-self: flex-start;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    font-size: 0.8125rem;
    color: #a78bfa;
    margin-bottom: 1rem;
    background: transparent;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-faint);
  }
  .meta .author {
    color: var(--text);
  }
  .meta .dot {
    opacity: 0.5;
  }
</style>
