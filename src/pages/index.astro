---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="Блог об ИИ для бизнеса"
  description="Upgrade - AI-агентство. Практические статьи про внедрение ИИ, автоматизацию и рост бизнеса."
>
  <main class="container posts-wide">
    <section class="hero-card">
      <div class="hero-text">
        <h1>Upgrade</h1>
        <p>Внедряем искусственный интеллект в бизнес. Пишем о том, что работает на практике: автоматизация, агенты, инструменты.</p>
        <a href="https://upgrade.ai/ai-course" class="cta" target="_blank" rel="noopener">Бесплатный мини-курс по ИИ</a>
      </div>
      <div class="hero-image">
        <img src="/founders.jpg" alt="Команда Upgrade" loading="eager" />
      </div>
    </section>

    <section>
      <div class="section-title">
        <h2>Последние статьи</h2>
        <a href="/blog/">Все статьи &rarr;</a>
      </div>
      <div class="posts-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  </main>

<style>
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    margin: 2rem 0 4rem;
    min-height: 480px;
  }
  .hero-text {
    padding: 3.5rem 3rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-text h1 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: #f5f1e8;
    font-weight: 500;
  }
  .hero-text p {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--text-muted);
    margin: 0 0 2rem;
    max-width: 420px;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 0.9rem 1.75rem;
    background: #e85c4a;
    color: #fff;
    border-radius: 9999px;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .cta:hover {
    background: #d14a38;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .hero-image {
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 820px) {
    .hero-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-text {
      padding: 2.5rem 1.5rem;
      order: 2;
    }
    .hero-image {
      aspect-ratio: 4 / 3;
      order: 1;
    }
  }
</style>
</BaseLayout>
