---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Блог об ИИ для бизнеса"
  description="Upgrade - AI-агентство. Практические статьи про внедрение ИИ, автоматизацию и рост бизнеса."
>
  <main class="container posts-wide">
    <section class="hero-card">
      <div class="hero-text">
        <h1>Upgrade</h1>
        <p>Внедряем искусственный интеллект в бизнес. Пишем о том, что работает на практике: автоматизация, агенты, инструменты.</p>
        <p class="daily-badge">Ежедневные обзоры новостей ИИ</p>
        <a href="https://upgrade-agency.ru/ai-course" class="cta" target="_blank" rel="noopener">Бесплатный мини-курс по ИИ</a>
      </div>
      <div class="hero-image">
        <img src="/founders.jpg" alt="Команда Upgrade" loading="eager" />
      </div>
    </section>

    <section>
      <div class="section-title">
        <h2>Все статьи</h2>
      </div>
      <div class="posts-list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  </main>

<style>
  .hero-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
    margin: 1.5rem 0 2.5rem;
    min-height: 340px;
  }
  .hero-text {
    padding: 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .hero-text h1 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    color: #f5f1e8;
    font-weight: 500;
  }
  .hero-text p {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    max-width: 440px;
  }
  .daily-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid var(--border);
    font-size: 0.8125rem !important;
    color: #60a5fa !important;
    margin: 0 0 1.5rem !important;
    align-self: flex-start;
    background: rgba(96, 165, 250, 0.08);
  }
  .daily-badge::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #60a5fa;
    box-shadow: 0 0 8px #60a5fa;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 0.875rem 1.75rem;
    background: #2563eb;
    color: #fff;
    border-radius: 9999px;
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .cta:hover {
    background: #1d4ed8;
    text-decoration: none;
    transform: translateY(-1px);
  }
  .hero-image {
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 820px) {
    .hero-card {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .hero-text {
      padding: 2.5rem 1.5rem;
      order: 2;
    }
    .hero-image {
      aspect-ratio: 4 / 3;
      order: 1;
    }
  }
</style>
</BaseLayout>
