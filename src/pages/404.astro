---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Страница не найдена"
  description="Запрашиваемая страница не существует."
  noindex={true}
>
  <main class="container">
    <div class="not-found">
      <h1>404</h1>
      <p>Страница не найдена</p>
      <a href="/">Вернуться на главную</a>
    </div>
  </main>
</BaseLayout>
